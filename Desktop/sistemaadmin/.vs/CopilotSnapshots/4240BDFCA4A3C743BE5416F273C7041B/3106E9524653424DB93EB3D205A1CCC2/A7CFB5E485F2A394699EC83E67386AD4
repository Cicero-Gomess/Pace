        private readonly string _token;
        private ProfileService _profileService;

        public FormPerfil(string token)
        {
            InitializeComponent();
            _token = token;
            _profileService = new ProfileService(token);
        }

        private void FormPerfil_Load(object sender, EventArgs e)
        {
            this.Text = "Sistema Administrativo - Perfil do Usuário";
            CarregarPerfil();
        }

        private async void CarregarPerfil()
        {
            try
            {
                btnCarregar.Enabled = false;
                btnCarregar.Text = "Carregando...";

                var json = await _profileService.GetMeAsync();

                // Parse do JSON
                var id = ExtrairValorInt(json, "id");
                var username = ExtrairValor(json, "username");
                var email = ExtrairValor(json, "email");
                var fotoPerfil = ExtrairValor(json, "foto_perfil");

                // Exibir dados
                if (this.Controls.Find("lblUsername", false).Length == 0)
                {
                    CriarInterface(id, username, email, fotoPerfil);
                }
                else
                {
                    // Atualizar dados existentes
                    Label lblUsernameValue = this.Controls["lblUsernameValue"] as Label;
                    Label lblEmailValue = this.Controls["lblEmailValue"] as Label;
                    Label lblIdValue = this.Controls["lblIdValue"] as Label;

                    if (lblUsernameValue != null) lblUsernameValue.Text = username;
                    if (lblEmailValue != null) lblEmailValue.Text = email;
                    if (lblIdValue != null) lblIdValue.Text = id.ToString();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Erro ao carregar perfil:\n{ex.Message}", "Erro",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            finally
            {
                btnCarregar.Enabled = true;
                btnCarregar.Text = "🔄 Recarregar";
            }
        }

