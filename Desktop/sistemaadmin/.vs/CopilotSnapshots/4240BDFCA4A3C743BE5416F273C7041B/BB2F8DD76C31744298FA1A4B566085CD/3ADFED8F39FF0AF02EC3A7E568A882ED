using System;
using System.Windows.Forms;
using sistemaadmin.Services;

namespace sistemaadmin
{
    public partial class FormLogin : Form
    {
        private readonly AuthService _authService;

        public FormLogin()
        {
            InitializeComponent();
            _authService = new AuthService();
        }

        private async void btnLogin_Click(object sender, EventArgs e)
        {
            try
            {
                var email = txtEmail.Text.Trim();
                var senha = txtSenha.Text.Trim();

                if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(senha))
                {
                    MessageBox.Show("Por favor, preencha email e senha.", "Validação", 
                        MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                btnLogin.Enabled = false;
                btnLogin.Text = "Conectando...";

                // Chamar serviço de autenticação
                var token = await _authService.Login(email, senha);

                if (string.IsNullOrEmpty(token))
                {
                    MessageBox.Show("Erro: Token não recebido.", "Erro", 
                        MessageBoxButtons.OK, MessageBoxIcon.Error);
                    btnLogin.Text = "Login";
                    btnLogin.Enabled = true;
                    return;
                }

                // Abrir FormPrincipal com o token
                FormPrincipal formPrincipal = new FormPrincipal(token);
                this.Hide();
                formPrincipal.ShowDialog();
                this.Close();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Erro de autenticação:\n{ex.Message}", "Erro de Login", 
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
                btnLogin.Text = "Login";
                btnLogin.Enabled = true;
            }
        }

        private void FormLogin_Load(object sender, EventArgs e)
        {
            this.Text = "Sistema Administrativo - Login";
            this.CenterToScreen();
        }
    }
}
