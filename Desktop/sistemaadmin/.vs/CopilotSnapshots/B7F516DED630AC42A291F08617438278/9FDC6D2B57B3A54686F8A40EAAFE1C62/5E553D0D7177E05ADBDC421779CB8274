using System;
using System.Collections.Generic;
using System.Text.RegularExpressions;
using System.Windows.Forms;
using sistemaadmin.Services;

namespace sistemaadmin
{
    public partial class FormDashboard : Form
    {
        private readonly string _token;
        private readonly PostService _postService;

        public FormDashboard(string token)
        {
            InitializeComponent();
            _token = token;
            _postService = new PostService(token);
        }

        private void FormDashboard_Load(object sender, EventArgs e)
        {
            CarregarDados();
        }

        private async void CarregarDados()
        {
            try
            {
                btnRecarregar.Enabled = false;
                btnRecarregar.Text = "Carregando...";

                var json = await _postService.GetFeedAsync();

                // Parse JSON
                var posts = ParsearPosts(json);

                // Calcular estatísticas
                int totalPosts = posts.Count;
                int totalLikes = 0;

                foreach (var post in posts)
                {
                    totalLikes += post.likes;
                }

                double media = totalPosts > 0 ? Math.Round((double)totalLikes / totalPosts, 2) : 0;

                // Atualizar cards
                lblCard1Valor.Text = totalPosts.ToString();
                lblCard2Valor.Text = totalLikes.ToString();
                lblCard3Valor.Text = media.ToString("F1");

                // Popular DataGridView
                dgvPosts.Rows.Clear();
                foreach (var post in posts)
                {
                    dgvPosts.Rows.Add(
                        post.id,
                        post.conteudo,
                        post.likes,
                        post.username,
                        post.data
                    );
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Erro ao carregar dashboard:\n{ex.Message}", "Erro",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
            finally
            {
                btnRecarregar.Enabled = true;
                btnRecarregar.Text = "🔄 Recarregar";
            }
        }

        private void BtnRecarregar_Click(object sender, EventArgs e)
        {
            CarregarDados();
        }

        private List<PostItem> ParsearPosts(string json)
        {
            var posts = new List<PostItem>();

            // Regex para extrair cada post
            MatchCollection matches = Regex.Matches(json, @"\{[^}]*""id"":\s*(\d+)[^}]*""conteudo"":\s*""([^""]*?)""[^}]*""likes"":\s*(\d+)[^}]*""usuario"":\s*\{[^}]*""username"":\s*""([^""]*?)""[^}]*""data"":\s*""([^""]*?)""");

            foreach (Match match in matches)
            {
                if (match.Groups.Count > 4)
                {
                    posts.Add(new PostItem
                    {
                        id = int.Parse(match.Groups[1].Value),
                        conteudo = UnescapeJson(match.Groups[2].Value),
                        likes = int.Parse(match.Groups[3].Value),
                        username = match.Groups[4].Value,
                        data = UnescapeJson(match.Groups[5].Value)
                    });
                }
            }

            return posts;
        }

        private string UnescapeJson(string text)
        {
            if (string.IsNullOrEmpty(text))
                return string.Empty;

            return text
                .Replace("\\n", "\n")
                .Replace("\\r", "\r")
                .Replace("\\t", "\t")
                .Replace("\\\"", "\"")
                .Replace("\\\\", "\\");
        }

        private class PostItem
        {
            public int id { get; set; }
            public string conteudo { get; set; }
            public int likes { get; set; }
            public string username { get; set; }
            public string data { get; set; }
        }
    }
}
